# OutfitAI Local Development Profile - MySQL
# Use this profile when running backend locally with your local MySQL server.

FLASK_CONFIG=development
SECRET_KEY=replace-with-32-byte-secret
JWT_SECRET_KEY=replace-with-32-byte-jwt-secret

# Force local MySQL even if DATABASE_URL is set.
USE_LOCAL_MYSQL=1

MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-local-mysql-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=outfit_fyp

# Optional; ignored when USE_LOCAL_MYSQL=1
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# VTO settings
REPLICATE_API_TOKEN=
HF_TOKEN=
HF_VTO_SPACE_ID=shabihhaider/IDM-VTON
