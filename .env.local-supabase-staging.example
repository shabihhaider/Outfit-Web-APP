# OutfitAI Local Development Profile - Supabase Staging
# Use this profile when running backend locally against a dedicated staging Supabase project.
# Do not use your production Supabase database for local testing.

FLASK_CONFIG=development
SECRET_KEY=replace-with-32-byte-secret
JWT_SECRET_KEY=replace-with-32-byte-jwt-secret

# Use DATABASE_URL directly.
USE_LOCAL_MYSQL=0
DATABASE_URL=postgresql://postgres:replace-password@db.replace-ref.supabase.co:5432/postgres

# Optional MySQL fallback values (unused while USE_LOCAL_MYSQL=0)
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=outfit_fyp

# VTO settings
REPLICATE_API_TOKEN=
HF_TOKEN=
HF_VTO_SPACE_ID=shabihhaider/IDM-VTON
